{
	"compilerOptions": {
		"module": "CommonJS",
		"target": "ES2019",
		"lib": ["ES2019", "DOM"],
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true
	},
	"include": [
		"nodes/**/*.ts",
		"credentials/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}