{
  "name": "n8n-nodes-extra-ai-providers",
  "version": "0.1.0",
  "description": "Custom n8n nodes for various AI Providers (OpenCode, 9Router, etc.)",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": "DutaKey",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc -w",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OpenCodeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OpenCode/OpenCode.node.js"
    ]
  },
  "dependencies": {
    "n8n-core": "^2.16.1",
    "n8n-workflow": "^2.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
